# Infocrats Document Drive - Environment Variables
# Copy this file to .env and update with your values for production
# 
# For Render.com deployment:
# 1. Set these environment variables in Render dashboard
# 2. Database connection string format: mysql://user:password@hostname:port/database
#
# For Docker deployment:
# Set these in docker-compose.yml environment section
#
# For local development:
# Keep these at defaults or set in your local .env file

# Database host (Render: your-mysql-hostname.render.com, Docker: db, Local: localhost)
DB_HOST=localhost

# Database user
DB_USER=root

# Database password
DB_PASSWORD=

# Database name
DB_NAME=document_system

# Optional: Application settings
# APP_ENV=development  # Set to 'production' on Render for production error handling
# APP_DEBUG=false      # Set to true for development, false for production
